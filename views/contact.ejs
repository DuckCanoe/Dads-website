<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact — <%- site.businessName %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="section-label">Get in touch</span>
      <h1>Let's talk about your situation</h1>
      <p>Whether you have a straightforward query or a complex matter, we're here to help.</p>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="contact-inner">
      <div class="contact-info">
        <span class="section-label">Our details</span>
        <h2>Reach us directly</h2>
        <p>Get in touch and one of our team will be in contact with you shortly.</p>
        <div class="contact-detail">

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 6.18 2 2 0 015 4h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L9.09 11.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 18z"/></svg>
            </div>
            <div class="contact-item-text">
              <span>Phone</span>
              <a href="tel:<%- site.phoneTel %>"><%- site.phone %></a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-item-text">
              <span>Email</span>
              <a href="mailto:<%- site.email %>"><%- site.email %></a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact-item-text">
              <span>Address</span>
              <p><%- site.address %></p>
            </div>
          </div>

        </div>
      </div>

      <div class="contact-form">
        <div id="form-success" class="form-message form-message--success" style="display:none;">
          Thank you! Your message has been sent. We will be in touch shortly.
        </div>
        <div id="form-error" class="form-message form-message--error" style="display:none;">
          Something went wrong. Please try again or call us directly.
        </div>

        <form id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="fname">First name</label>
              <input type="text" id="fname" name="fname" placeholder="Jane" required>
            </div>
            <div class="form-group">
              <label for="lname">Last name</label>
              <input type="text" id="lname" name="lname" placeholder="Smith" required>
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required>
          </div>
          <div class="form-group">
            <label for="phone">Phone number</label>
            <input type="tel" id="phone" name="phone" placeholder="021 000 0000">
          </div>
          <div class="form-group">
            <label for="service">Area of enquiry</label>
            <select id="service" name="service" required>
              <option value="" disabled selected>Select a service</option>
              <option>Property Law</option>
              <option>Business Law</option>
              <option>Family Law</option>
              <option>Wills &amp; Estates</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="Briefly describe your situation..." required></textarea>
          </div>
          <button type="submit" class="form-submit" id="form-btn">Send enquiry</button>
        </form>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
