<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact — <%- site.businessName %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="section-label">Get in touch</span>
      <h1>Let's talk about your situation</h1>
      <p>Whether you have a straightforward query or a complex matter, we're here to help.</p>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="contact-inner">
      <div class="contact-info">
        <span class="section-label">Our details</span>
        <h2>Reach us directly</h2>
        <p>Get in touch and one of our team will be in contact with you shortly.</p>
        <div class="contact-detail">

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 6.18 2 2 0 015 4h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L9.09 11.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 18z"/></svg>
            </div>
            <div class="contact-item-text">
              <span>Phone</span>
              <a href="tel:<%- site.phoneTel %>"><%- site.phone %></a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item-icon">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-item-text">
              <span>Email</span>
              <a href="mailto:<%- site.email %>"><%- site.email %></a>
            </div>
          </div>

        </div>
      </div>
      <%- include('partials/contact-form') %>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
